    "@eslint/js": "^9.13.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "tsx": "^4.19.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
